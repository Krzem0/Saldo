<Window x:Class="Saldo.Desktop.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Saldo.Desktop.Wpf.Views"
        Title="Saldo" Height="600" Width="960"
        WindowStartupLocation="CenterScreen">
    <TabControl SelectionChanged="TabControl_SelectionChanged">
        <TabItem Header="Transactions">
            <views:TransactionListView DataContext="{Binding TransactionList}"/>
        </TabItem>
        <TabItem Header="Categories">
            <views:ReferenceListView DataContext="{Binding Categories}"/>
        </TabItem>
        <TabItem Header="Members">
            <views:ReferenceListView DataContext="{Binding Members}"/>
        </TabItem>
        <TabItem Header="Counterparties">
            <views:ReferenceListView DataContext="{Binding Counterparties}"/>
        </TabItem>
    </TabControl>
</Window>
