<UserControl x:Class="Saldo.Desktop.Wpf.Views.TransactionListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Month navigation -->
        <Grid Grid.Row="0" Margin="8,8,8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="‹" Command="{Binding PreviousMonthCommand}" Padding="10,4" FontSize="18"/>

            <!-- Clickable month label + picker popup -->
            <Grid Grid.Column="1" HorizontalAlignment="Center">
                <Button x:Name="MonthPickerButton"
                        Command="{Binding OpenMonthPickerCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Padding="8,2">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E3F2FD"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#BBDEFB"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="{Binding MonthLabel}"
                               FontSize="16" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </Button>

                <Popup IsOpen="{Binding IsMonthPickerOpen, Mode=TwoWay}"
                       PlacementTarget="{Binding ElementName=MonthPickerButton}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade">
                    <Border Background="White"
                            BorderBrush="#BDBDBD"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10">
                        <StackPanel Width="220">

                            <!-- Year navigation inside popup -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="‹"
                                        Command="{Binding PreviousPickerYearCommand}"
                                        Padding="8,2" BorderThickness="0"
                                        Background="Transparent" Cursor="Hand"
                                        FontSize="18"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding PickerYearText, UpdateSourceTrigger=LostFocus}"
                                         FontSize="14"
                                         FontWeight="SemiBold"
                                         HorizontalContentAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         BorderThickness="1"
                                         BorderBrush="#D0D0D0"
                                         Background="White"
                                         Padding="4,2"
                                         Margin="6,0"
                                         Width="90"/>
                                <Button Grid.Column="2" Content="›"
                                        Command="{Binding NextPickerYearCommand}"
                                        Padding="8,2" BorderThickness="0"
                                        Background="Transparent" Cursor="Hand"
                                        FontSize="18"/>
                            </Grid>

                            <!-- 4×3 month grid -->
                            <ItemsControl ItemsSource="{Binding PickerMonths}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="4" Columns="3"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding Label}"
                                                CommandParameter="{Binding Number}"
                                                Command="{Binding DataContext.SelectMonthCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Margin="2" Padding="4,6" Cursor="Hand" FontSize="12">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}"
                                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                                        BorderThickness="1" CornerRadius="4"
                                                                        Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#E3F2FD"/>
                                                                        <Setter Property="BorderBrush" Value="#1E88E5"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter Property="Background" Value="#BBDEFB"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>

            <Button Grid.Column="2" Content="›" Command="{Binding NextMonthCommand}" Padding="10,4" FontSize="18"/>
        </Grid>

        <!-- Summary bar -->
        <Border Grid.Row="1" Background="#F0F4F8" Padding="12,6" Margin="8,0,8,4" CornerRadius="4">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Income: " FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Summary.TotalIncome, StringFormat={}{0:N2}}"
                           Foreground="#2E7D32" FontWeight="SemiBold" Margin="0,0,20,0"/>
                <TextBlock Text="Expense: " FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Summary.TotalExpense, StringFormat={}{0:N2}}"
                           Foreground="#C62828" FontWeight="SemiBold" Margin="0,0,20,0"/>
                <TextBlock Text="Balance: " FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Summary.Balance, StringFormat={}{0:N2}}"
                           FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- Transaction list -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Transactions}"
                  SelectedItem="{Binding SelectedTransaction}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#FAFAFA"
                  Margin="8,0,8,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Date"
                                    Binding="{Binding Date, StringFormat={}{0:dd.MM.yyyy}}"
                                    Width="90"/>
                <DataGridTextColumn Header="Direction"
                                    Binding="{Binding Direction}"
                                    Width="80"/>
                <DataGridTextColumn Header="Amount"
                                    Binding="{Binding Amount, StringFormat={}{0:N2}}"
                                    Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="0,0,4,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Category"    Binding="{Binding CategoryName}"    Width="120"/>
                <DataGridTextColumn Header="Payer"       Binding="{Binding PayerName}"       Width="110"/>
                <DataGridTextColumn Header="Counterparty" Binding="{Binding CounterpartyName}" Width="140"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}"     Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Action buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="8,6,8,8">
            <Button Content="+ Add"  Command="{Binding AddCommand}"    Padding="14,5" Margin="0,0,6,0"/>
            <Button Content="Edit"   Command="{Binding EditCommand}"   Padding="14,5" Margin="0,0,6,0"/>
            <Button Content="Delete" Command="{Binding DeleteCommand}" Padding="14,5"/>
        </StackPanel>
    </Grid>
</UserControl>
